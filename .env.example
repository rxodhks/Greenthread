# Optional. 설정 시 업로드 이미지에 대해 OpenAI 비전으로 시나리오를 고릅니다.
OPENAI_API_KEY=

# 선택. 기본 gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Upstash Redis (Vercel 연동). 설정 시 스레드 이벤트·텔레메트리가 인스턴스 간 공유됩니다.
# 표준 이름:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Vercel 일부 템플릿·구 KV 연동 이름(둘 중 한 쌍이면 됨):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# CTA 링크 (클라이언트). 미설정 시 mailto 기본값을 씁니다.
# NEXT_PUBLIC_GT_DONATE_URL=https://www.globalgiving.org/
# NEXT_PUBLIC_GT_ALTERNATIVES_URL=mailto:hello@example.com?subject=Greenthread%20대체%20행동

# 텔레메트리 요약 API(/api/admin/metrics) 및 /admin/metrics 페이지 조회용. 강한 임의 문자열을 사용하세요.
# METRICS_ADMIN_SECRET=

# --- 배포 환경 체크리스트 (Production / Preview)
# 동일 프로젝트·동일 환경에서 스캔·지도·/admin/metrics 가 같은 Redis 를 봐야 집계가 맞습니다.
# [ ] UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN (또는 KV_REST_API_URL + KV_REST_API_TOKEN) 쌍이
#     Production(및 Preview 사용 시 Preview)에 설정됨
# [ ] METRICS_ADMIN_SECRET 이 Production 에 설정됨 (/admin/metrics·telemetry:week 용)
# [ ] 변수 저장 후 Redeploy 가 한 번 이상 돌아감
# [ ] (선택) OPENAI_API_KEY, NEXT_PUBLIC_GT_DONATE_URL, NEXT_PUBLIC_GT_ALTERNATIVES_URL
#
# Vercel: Project → Settings → Environment Variables → 환경별 값 확인 후 Deployments → Redeploy
