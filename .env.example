# Optional. 설정 시 업로드 이미지에 대해 OpenAI 비전으로 시나리오를 고릅니다.
OPENAI_API_KEY=

# 선택. 기본 gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Upstash Redis (Vercel 연동). 설정 시 스레드 이벤트·텔레메트리가 인스턴스 간 공유됩니다.
# 표준 이름:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Vercel 일부 템플릿·구 KV 연동 이름(둘 중 한 쌍이면 됨):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# CTA 링크 (클라이언트). 미설정 시 mailto 기본값을 씁니다.
# NEXT_PUBLIC_GT_DONATE_URL=https://www.globalgiving.org/
# NEXT_PUBLIC_GT_ALTERNATIVES_URL=mailto:hello@example.com?subject=Greenthread%20대체%20행동

# 텔레메트리 요약 API(/api/admin/metrics) 및 /admin/metrics 페이지 조회용. 강한 임의 문자열을 사용하세요.
# METRICS_ADMIN_SECRET=

# --- Vercel 재배포 시 (대시보드 → Project → Settings → Environment Variables)
# .env.local 은 Git/업로드에 포함되지 않습니다. 아래를 Production(및 필요 시 Preview)에 각각 등록한 뒤
# Deployments → 최신 배포 ⋮ → Redeploy 하세요.
#   OPENAI_API_KEY (선택)
#   UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN (선택, 스레드·텔레메트리 공유)
#   METRICS_ADMIN_SECRET (.env.local 과 동일 값이면 /admin/metrics 조회 가능)
#   NEXT_PUBLIC_* CTA URL (선택)
